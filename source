		OldSend = hookfunction(Network.send, function(...)
			local args = {...}

			if args[1] == "shoot_gun" and c().AimAssiant and c().AimAssiantTarget then  
				local TargetPart = c().AimAssiantTarget:FindFirstChild((c().PartTargetSelected or "Head"))
				local ClientPosition = RootPart.Position
				local TargetPosition = TargetPart.Position 
				local Vector = TargetPosition - ClientPosition
				local CurrentStart = tick()
				local GravityWorld = Vector3.new(0, -workspace.Gravity, 0)
				local ProjectileSpeed = 1000
				local TravelTime = getBallisticFlightTime(Vector, GravityWorld, ProjectileSpeed)
				TargetHistory[c().AimAssiantTarget] = TargetHistory[c().AimAssiantTarget] or {}
				if #TargetHistory[c().AimAssiantTarget] >= 3 then table.remove(TargetHistory[c().AimAssiantTarget], 1) end
				table.insert(TargetHistory[c().AimAssiantTarget], {pos = TargetPosition,time = CurrentStart})

				local hist = TargetHistory[c().AimAssiantTarget]
				local approxVel = Vector3.zero

				if #hist == 1 then
					local p1 = hist[1]
					local dt = math.max(CurrentStart - p1.time, 1e-6)
					approxVel = (TargetPosition - p1.pos) / dt

				elseif #hist == 2 then
					local p1, p2 = hist[1], hist[2]
					local dt = math.max(p2.time - p1.time, 1e-6)
					approxVel = (p2.pos - p1.pos) / dt

				elseif #hist >= 3 then
					local p1, p2, p3 = hist[#hist-2], hist[#hist-1], hist[#hist]
					local dt1 = math.max(p2.time - p1.time, 1e-6)
					local dt2 = math.max(p3.time - p2.time, 1e-6)
					local v1 = (p2.pos - p1.pos) / dt1
					local v2 = (p3.pos - p2.pos) / dt2
					local accel = (v2 - v1) / math.max(dt1 + dt2, 1e-6)
					local weight = dt2 / (dt1 + dt2)
					approxVel = v2 * weight + v1 * (1 - weight) + accel * dt2 * 0.5
				end

				local Predict_Position = PredictPosition(TargetPosition, approxVel, TravelTime, GravityWorld)
				local isShotgun = Character:FindFirstChildWhichIsA("Tool") and Character:FindFirstChildWhichIsA("Tool"):GetAttribute("AmmoType") == "shotgun"
				local behindWall = c().WallBang and Character:FindFirstChildWhichIsA("Tool") and Character:FindFirstChildWhichIsA("Tool"):GetAttribute("AmmoType") ~= "shotgun" and IsBehindWall(ClientPosition, Predict_Position)
				args[3] = isShotgun and CFrame.new(ClientPosition, Predict_Position) or (behindWall and CFrame.new(math.huge, math.huge, math.huge) or CFrame.new(ClientPosition, Predict_Position))

				for _, v in pairs(args[4]) do
					for _, x in pairs(v) do
						x.Normal = Vector3.new(0, 1, 0)
						x.Position = Predict_Position
						x.Instance = TargetPart
					end
				end

				if c().MultiShoot then
					OldSend(table.unpack(args))
				end
					
				local DistanceTarget = (Predict_Position - ClientPosition).Magnitude
				if DistanceTarget > 0.1 then  
					local TracerAim = Instance.new("Part", workspace)
					TracerAim.Size = Vector3.new(0.02, 0.02, DistanceTarget)
					TracerAim.Color = Color3.fromRGB(208, 16, 233)
					TracerAim.CFrame = CFrame.new(ClientPosition, Predict_Position) * CFrame.new(0, 0, -DistanceTarget / 2)
					TracerAim.Material = Enum.Material.Neon
					TracerAim.CanCollide = false
					TracerAim.Anchored = true

					Debris:AddItem(TracerAim, 0.4)
				end
			end

			return OldSend(table.unpack(args))
		end)
	end 

