function func.Snap()
	local BasePosition = Char.get_hrp().Position
	local OffsetY = c().SnapAmount or 1
	while task.wait() do 
		if c().Snap then  
			xpcall(function()
				if IsAlive(Character) then
					local CurrentOffset = c().SnapAmount or 1

					if CurrentOffset ~= OffsetY then
						OffsetY = CurrentOffset
					end

					local CurrentY = Char.get_hrp().Position.Y
					local deltaY = GetDeltaY(BasePosition.Y, CurrentY, CurrentOffset)			
					Char.get():PivotTo(Char.get_hrp().CFrame * CFrame.new(0, deltaY, 0))
				end
			end,warn)
		end
	end
end


